<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Настройки"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:layout_margin="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Часовой пояс -->
    <TextView
        android:id="@+id/timezoneLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Часовой пояс:"
        android:textSize="20sp"
        android:textColor="@color/white"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintStart_toStartOf="parent" />

    <SeekBar
        android:id="@+id/timezoneSeekBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/timezoneLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/timezoneValueText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Часовой пояс: +2 (UTC+2 - Москва)"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/timezoneSeekBar"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Качество -->
    <TextView
        android:id="@+id/qualityLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Качество видео:"
        android:textSize="20sp"
        android:textColor="@color/white"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/timezoneValueText"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/qualityModeButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Нажмите для смены"
        android:textSize="18sp"
        android:textColor="@color/accent"
        android:padding="16dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/qualityLabel"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/qualityModeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Качество: Авто"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/qualityModeButton"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Язык -->
    <TextView
        android:id="@+id/languageLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Язык интерфейса:"
        android:textSize="20sp"
        android:textColor="@color/white"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/qualityModeText"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/languageButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Нажмите для смены"
        android:textSize="18sp"
        android:textColor="@color/accent"
        android:padding="16dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/languageLabel"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/languageText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Язык: Русский"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/languageButton"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/helpText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Используйте пульт для навигации. Нажмите OK для выбора опции."
        android:textSize="14sp"
        android:textColor="@color/text_hint"
        android:gravity="center"
        android:layout_margin="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
