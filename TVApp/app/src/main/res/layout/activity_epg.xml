<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Программа передач"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:layout_margin="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/currentTimeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Время: --:--"
        android:textSize="18sp"
        android:textColor="@color/accent"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/timeOffsetText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Смещение: 0ч"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toBottomOf="@id/currentTimeText"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="4dp" />

    <!-- Общая временная шкала -->
    <HorizontalScrollView
        android:id="@+id/timeScaleScroll"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:scrollbars="none"
        android:background="@color/card_background"
        app:layout_constraintTop_toBottomOf="@id/timeOffsetText"
        app:layout_constraintStart_toEndOf="@id/channelLabelsArea"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/timeScaleContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="16dp">

            <!-- Временные метки будут добавлены программно -->
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Вертикальная прокрутка каналов -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/channelLabelsScroll"
        android:layout_width="150dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:scrollbars="vertical"
        app:layout_constraintTop_toBottomOf="@id/timeScaleScroll"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/channelLabelsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Названия каналов будут добавлены программно -->
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Область для названий каналов над лентой -->
    <FrameLayout
        android:id="@+id/channelLabelsArea"
        android:layout_width="150dp"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:background="@color/card_background"
        app:layout_constraintTop_toBottomOf="@id/timeOffsetText"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Каналы"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_gravity="center" />
    </FrameLayout>

    <!-- Основная область с программой передач -->
    <HorizontalScrollView
        android:id="@+id/epgHorizontalScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:fillViewport="true"
        android:scrollbars="horizontal"
        app:layout_constraintTop_toBottomOf="@id/timeScaleScroll"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/channelLabelsScroll"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/epgVerticalScroll"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="vertical">

            <FrameLayout
                android:id="@+id/epgGridContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <!-- Программа передач будет добавлена программно -->
            </FrameLayout>
        </androidx.core.widget.NestedScrollView>
    </HorizontalScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
